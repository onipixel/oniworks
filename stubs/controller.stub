package controllers

import (
	"github.com/onipixel/oniworks/framework/database"
	onihttp "github.com/onipixel/oniworks/framework/http"
)

// {{.Name}}Controller handles HTTP requests for the {{.Name}} resource.
// Wire routes in your router:
//
//	ctrl := &{{.Name}}Controller{db: db}
//	r.Get("/{{.NameSnake}}s",         ctrl.Index)
//	r.Post("/{{.NameSnake}}s",        ctrl.Store)
//	r.Get("/{{.NameSnake}}s/:id",     ctrl.Show)
//	r.Put("/{{.NameSnake}}s/:id",     ctrl.Update)
//	r.Delete("/{{.NameSnake}}s/:id",  ctrl.Destroy)
type {{.Name}}Controller struct {
	db *database.DB
}

// Index returns a paginated list of {{.Name}} records.
func (ctrl *{{.Name}}Controller) Index(c *onihttp.Context) error {
	page := 1
	var items []map[string]any
	result, err := ctrl.db.Table("{{.NameSnake}}s").
		OrderBy("id DESC").
		Paginate(page, 20, &items)
	if err != nil {
		return c.Abort(500, "failed to load {{.NameSnake}}s")
	}
	return c.JSON(200, onihttp.Map{
		"data": items,
		"meta": onihttp.Map{
			"total":        result.Total,
			"current_page": result.CurrentPage,
			"last_page":    result.LastPage,
			"per_page":     result.PerPage,
		},
	})
}

// Show returns a single {{.Name}} by ID.
func (ctrl *{{.Name}}Controller) Show(c *onihttp.Context) error {
	id := c.Param("id")
	var item map[string]any
	if err := ctrl.db.Table("{{.NameSnake}}s").Where("id = ?", id).First(&item); err != nil {
		if err == database.ErrNotFound {
			return c.Abort(404, "{{.NameSnake}} not found")
		}
		return c.Abort(500, "failed to load {{.NameSnake}}")
	}
	return c.JSON(200, onihttp.Map{"data": item})
}

