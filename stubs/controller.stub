	}
	if err := c.Validate(&in); err != nil {
		return err // 422 with field errors
	}
	row := database.Map{
		// Map input fields to columns:
		// "name": in.Name,
	}
	if err := ctrl.db.Table("{{.NameSnake}}s").Insert(row); err != nil {
		return c.Abort(500, "failed to create {{.NameSnake}}")
	}
	return c.JSON(201, onihttp.Map{"data": row})
}

// Update validates and modifies an existing {{.Name}}.
func (ctrl *{{.Name}}Controller) Update(c *onihttp.Context) error {
	id := c.Param("id")
	var in struct {
		// Add your input fields here:
		// Name string `json:"name" validate:"required,min=2,max=255"`
	}
	if err := c.Validate(&in); err != nil {
		return err
	}
	if err := ctrl.db.Table("{{.NameSnake}}s").
		Where("id = ?", id).
		Update(database.Map{
			// "name": in.Name,
		}); err != nil {
		return c.Abort(500, "failed to update {{.NameSnake}}")
	}
	return c.JSON(200, onihttp.Map{"message": "updated"})
}

// Destroy deletes a {{.Name}} by ID.
func (ctrl *{{.Name}}Controller) Destroy(c *onihttp.Context) error {
	id := c.Param("id")
	if err := ctrl.db.Table("{{.NameSnake}}s").Where("id = ?", id).Delete(); err != nil {
		return c.Abort(500, "failed to delete {{.NameSnake}}")
	}
	return c.NoContent()
}
